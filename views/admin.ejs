<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Console • AttendTrack</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/static/admin.css">
</head>
<body>

<!-- Ambient background decorations (matches login page) -->
<div class="bg-particles">
  <span></span><span></span><span></span><span></span><span></span><span></span>
</div>
<div class="bg-deco"></div>

<div id="app">
<div id="toast" class="toast"></div>

<!-- ═══════════════════════════════════════════
     SIDEBAR
═══════════════════════════════════════════ -->
<nav class="sidebar" id="sidebar">

  <!-- Logo -->
  <div class="sidebar-header" style="margin-bottom:20px">
    <div class="sidebar-logo">
      <div class="logo-mark">
        <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 12L11 14L15 10M21 12C21 16.97 16.97 21 12 21C7.03 21 3 16.97 3 12C3 7.03 7.03 3 12 3C16.97 3 21 7.03 21 12Z"/>
        </svg>
      </div>
      <div class="logo-text">
        <div style="font-size:14px;font-weight:800;color:var(--text);letter-spacing:-.3px">AttendTrack</div>
        <div style="font-size:11px;color:var(--text2)">Admin Console</div>
      </div>
    </div>
  </div>

  <!-- Admin badge -->
  <div class="admin-badge">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
    </svg>
    <span style="font-size:11px;font-weight:700">Super Administrator</span>
  </div>

  <!-- Nav sections -->
  <div style="font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);padding:0 4px;margin-bottom:6px">Overview</div>
  <nav style="display:flex;flex-direction:column;gap:3px;margin-bottom:16px">
    <button class="nav-item active" onclick="switchView('dashboard', this)">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
        <rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/>
      </svg>
      Dashboard
    </button>
  </nav>

  <div style="font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);padding:0 4px;margin-bottom:6px">People</div>
  <nav style="display:flex;flex-direction:column;gap:3px;margin-bottom:16px">
    <button class="nav-item" onclick="switchView('students', this)">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
      Students
    </button>
    <button class="nav-item" onclick="switchView('teachers', this)">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
      Teachers
    </button>
    <button class="nav-item" onclick="switchView('users', this)">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/>
      </svg>
      All Users
    </button>
  </nav>

  <div style="font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);padding:0 4px;margin-bottom:6px">Management</div>
  <nav style="display:flex;flex-direction:column;gap:3px">
    <button class="nav-item" onclick="switchView('registrations', this)">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
        <path d="M22 2l-4 4m0 0l-4-4m4 4V14"/>
      </svg>
      Registrations
      <span class="nav-badge" id="sbPendingBadge">5</span>
    </button>
    <button class="nav-item" onclick="switchView('logs', this)">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
        <rect x="9" y="3" width="6" height="4" rx="1"/>
        <line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="12" y2="16"/>
      </svg>
      Attendance Logs
    </button>
  </nav>

  <!-- Sidebar footer -->
  <div style="margin-top:auto;padding-top:20px;border-top:1px solid var(--border)">
    <div style="display:flex;align-items:center;gap:10px;padding:10px 12px;background:rgba(79,172,254,.06);border:1px solid var(--border);border-radius:10px">
      <div class="avatar" style="background:var(--grad-btn);width:32px;height:32px;font-size:11px;flex-shrink:0">AD</div>
      <div style="flex:1;min-width:0">
        <div style="font-size:12px;font-weight:700;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">Administrator</div>
        <div style="font-size:10px;color:var(--text3)">Super Admin</div>
      </div>
      <button class="btn btn-xs btn-ghost" onclick="window.location='/logout'" style="font-size:10px;padding:4px 9px;flex-shrink:0">Out</button>
    </div>
  </div>
</nav>

<!-- ═══════════════════════════════════════════
     MAIN AREA
═══════════════════════════════════════════ -->
<div class="main">

  <!-- Header -->
  <header>
    <!-- Mobile menu toggle -->
    <button class="menu-btn" onclick="toggleSidebar()" style="display:none;width:34px;height:34px;background:rgba(79,172,254,.08);border:1px solid var(--border);border-radius:8px;cursor:pointer;align-items:center;justify-content:center;flex-shrink:0">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--text)" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>

    <div>
      <div class="page-title" id="headerTitle">Dashboard</div>
    </div>

    <div style="display:flex;align-items:center;gap:12px;margin-left:auto">
      <span style="font-size:11px;color:var(--text3)" id="headerDate"></span>
      <div class="admin-chip">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        Admin
      </div>
    </div>
  </header>

  <!-- Content area -->
  <div class="content">

    <!-- ═══════ DASHBOARD ═══════ -->
    <div class="view active" id="view-dashboard">
      <div style="margin-bottom:24px">
        <div style="font-size:26px;font-weight:800;color:var(--text);letter-spacing:-.5px;margin-bottom:4px" id="dashGreeting">Good day, Admin 👋</div>
        <div style="font-size:13px;color:var(--text2)">Here's what's happening today.</div>
      </div>

      <!-- Metrics -->
      <div class="metrics-grid">
        <div class="metric-card">
          <div class="metric-icon">🎓</div>
          <div class="metric-label">Total Students</div>
          <div class="metric-value" id="mStudents">—</div>
        </div>
        <div class="metric-card" style="--card-accent:var(--green)">
          <div class="metric-icon">✅</div>
          <div class="metric-label">Present Today</div>
          <div class="metric-value" style="color:var(--green)">4</div>
        </div>
        <div class="metric-card" style="--card-accent:var(--amber)">
          <div class="metric-icon">👨‍🏫</div>
          <div class="metric-label">Total Teachers</div>
          <div class="metric-value" id="mTeachers">—</div>
        </div>
        <div class="metric-card">
          <div class="metric-icon">📋</div>
          <div class="metric-label">Pending Approvals</div>
          <div class="metric-value" style="color:var(--amber)" id="dPending">—</div>
        </div>
      </div>

      <!-- 2-col: attendance + registrations -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px">

        <div class="card">
          <div class="card-header">
            <h3>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--blue-light)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
              Today's Attendance
            </h3>
          </div>
          <div class="card-body" style="display:block;padding:20px">
            <div class="prog-row">
              <span class="prog-label">Present</span>
              <div class="prog-bar"><div class="prog-fill" style="width:67%;background:var(--green)"></div></div>
              <span class="prog-val" style="color:var(--green)">67% (4)</span>
            </div>
            <div class="prog-row">
              <span class="prog-label">Absent</span>
              <div class="prog-bar"><div class="prog-fill" style="width:17%;background:var(--red)"></div></div>
              <span class="prog-val" style="color:var(--red)">17% (1)</span>
            </div>
            <div class="prog-row">
              <span class="prog-label">Late</span>
              <div class="prog-bar"><div class="prog-fill" style="width:16%;background:var(--amber)"></div></div>
              <span class="prog-val" style="color:var(--amber)">16% (1)</span>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <h3>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--blue-light)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 2l-4 4m0 0l-4-4m4 4V14"/></svg>
              Registration Status
            </h3>
          </div>
          <div class="card-body" style="display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:16px">
            <div style="padding:14px;background:rgba(251,191,36,.08);border:1px solid rgba(251,191,36,.18);border-radius:10px;text-align:center">
              <div style="font-size:24px;font-weight:800;color:var(--amber)" id="dPending2">—</div>
              <div style="font-size:11px;color:var(--text2);margin-top:3px">Pending</div>
            </div>
            <div style="padding:14px;background:var(--green-bg);border:1px solid rgba(34,211,165,.18);border-radius:10px;text-align:center">
              <div style="font-size:24px;font-weight:800;color:var(--green)">—</div>
              <div style="font-size:11px;color:var(--text2);margin-top:3px">Approved Today</div>
            </div>
            <div style="padding:14px;background:rgba(79,172,254,.08);border:1px solid var(--border2);border-radius:10px;text-align:center">
              <div style="font-size:24px;font-weight:800;color:var(--blue-light)" id="uStudents2">—</div>
              <div style="font-size:11px;color:var(--text2);margin-top:3px">Students</div>
            </div>
            <div style="padding:14px;background:rgba(79,172,254,.08);border:1px solid var(--border2);border-radius:10px;text-align:center">
              <div style="font-size:24px;font-weight:800;color:var(--blue-light)" id="uTeachers2">—</div>
              <div style="font-size:11px;color:var(--text2);margin-top:3px">Teachers</div>
            </div>
          </div>
        </div>

      </div>

      <!-- Today's classes -->
      <div class="card" style="margin-bottom:16px">
        <div class="card-header">
          <h3>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--blue-light)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Today's Classes
          </h3>
          <span style="font-size:11px;color:var(--text3)" id="todayDayLabel"></span>
        </div>
        <div class="card-body" style="display:block;padding:14px" id="todayClassesBody">
          <div style="text-align:center;padding:24px;color:var(--text3);font-size:13px">Loading…</div>
        </div>
      </div>

      <!-- Quick actions -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
        <div class="card">
          <div class="card-header"><h3>Quick Actions</h3></div>
          <div class="card-body" style="display:flex;flex-direction:column;gap:8px;padding:16px">
            <button class="btn btn-primary" onclick="openAddModal()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Add New User
            </button>
            <button class="btn btn-ghost" onclick="toast('Generating report…')">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Generate Report
            </button>
          </div>
        </div>
        <div class="card">
          <div class="card-header"><h3>System Tools</h3></div>
          <div class="card-body" style="display:flex;flex-direction:column;gap:8px;padding:16px">
            <button class="btn btn-primary" onclick="toast('Syncing data…')">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
              Sync Data
            </button>
            <button class="btn btn-ghost" onclick="toast('Backup started…')">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Backup System
            </button>
          </div>
        </div>
      </div>
    </div><!-- /dashboard -->


    <!-- ═══════ STUDENTS ═══════ -->
    <div class="view" id="view-students">
      <div style="margin-bottom:20px">
        <div style="font-size:22px;font-weight:800;color:var(--text);letter-spacing:-.4px;margin-bottom:3px">Students</div>
        <div style="font-size:13px;color:var(--text2)">Manage registered student accounts.</div>
      </div>

      <div class="card">
        <div class="card-header">
          <h3>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--blue-light)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            Registered Students
          </h3>
          <div style="display:flex;gap:8px">
            <button class="btn btn-xs btn-primary" onclick="openAddModal('student')">+ Add Student</button>
            <button class="btn btn-xs btn-ghost" onclick="toast('Exporting…')">↓ Export</button>
          </div>
        </div>
        <div class="card-body" style="display:block;padding:14px 16px 8px">
          <div style="display:flex;gap:10px;flex-wrap:wrap">
            <div class="search-bar" style="max-width:320px;flex:1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              <input id="stuSearch" placeholder="Search by name or ID…" oninput="filterTable('studentsTbody', this.value)">
            </div>
          </div>
        </div>
        <div style="overflow-x:auto">
          <table class="table">
            <thead>
              <tr>
                <th>Name</th><th>Student ID</th><th>Course</th><th>Section</th><th></th>
              </tr>
            </thead>
            <tbody id="studentsTbody"></tbody>
          </table>
        </div>
      </div>
    </div><!-- /students -->


    <!-- ═══════ TEACHERS ═══════ -->
    <div class="view" id="view-teachers">
      <div style="margin-bottom:20px">
        <div style="font-size:22px;font-weight:800;color:var(--text);letter-spacing:-.4px;margin-bottom:3px">Teachers</div>
        <div style="font-size:13px;color:var(--text2)">View, manage, and organize teacher profiles and assigned classes.</div>
      </div>

      <div class="card">
        <div class="card-header">
          <h3>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--blue-light)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Registered Teachers
          </h3>
          <div style="display:flex;gap:8px">
            <button class="btn btn-xs btn-primary" onclick="openAddModal('teacher')">+ Add Teacher</button>
            <button class="btn btn-xs btn-ghost" onclick="toast('Exporting…')">↓ Export</button>
          </div>
        </div>
        <div class="card-body" style="display:block;padding:14px 16px 8px">
          <div class="search-bar" style="max-width:320px">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input placeholder="Search by name or employee ID…" oninput="filterTable('teachersTbody', this.value)">
          </div>
        </div>
        <div style="overflow-x:auto">
          <table class="table">
            <thead>
              <tr>
                <th>Name</th><th>Employee ID</th><th>Subject</th><th></th>
              </tr>
            </thead>
            <tbody id="teachersTbody"></tbody>
          </table>
        </div>
      </div>
    </div><!-- /teachers -->


    <!-- ═══════ ALL USERS ═══════ -->
    <div class="view" id="view-users">
      <div style="margin-bottom:20px">
        <div style="font-size:22px;font-weight:800;color:var(--text);letter-spacing:-.4px;margin-bottom:3px">All Users</div>
        <div style="font-size:13px;color:var(--text2)">Click a name to view profile details.</div>
      </div>

      <!-- Stats row -->
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:16px">
        <div class="metric-card" style="min-height:auto;padding:16px">
          <div class="metric-label">Total Users</div>
          <div class="metric-value" id="uTotal">—</div>
        </div>
        <div class="metric-card" style="min-height:auto;padding:16px">
          <div class="metric-label">Students</div>
          <div class="metric-value" style="color:var(--blue-light)" id="uStudents">—</div>
        </div>
        <div class="metric-card" style="min-height:auto;padding:16px">
          <div class="metric-label">Teachers</div>
          <div class="metric-value" style="color:var(--green)" id="uTeachers">—</div>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h3>User Directory</h3></div>
        <div class="card-body" style="display:block;padding:14px 16px 8px">
          <div style="display:flex;gap:10px;flex-wrap:wrap">
            <div class="search-bar" style="flex:1;min-width:200px">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              <input placeholder="Search by name, email, or ID…" oninput="filterTable('usersTbody', this.value)">
            </div>
            <select class="form-select" style="width:150px" onchange="filterTable('usersTbody', '', this.value)">
              <option value="">All Roles</option>
              <option value="student">Students</option>
              <option value="teacher">Teachers</option>
            </select>
          </div>
        </div>
        <div style="overflow-x:auto">
          <table class="table">
            <thead>
              <tr>
                <th>Name</th><th>Role</th><th>Course / Subject</th><th>Section</th><th>Email</th>
              </tr>
            </thead>
            <tbody id="usersTbody"></tbody>
          </table>
        </div>
      </div>
    </div><!-- /users -->


    <!-- ═══════ REGISTRATIONS ═══════ -->
    <div class="view" id="view-registrations">
      <div style="margin-bottom:20px">
        <div style="font-size:22px;font-weight:800;color:var(--text);letter-spacing:-.4px;margin-bottom:3px">Registrations</div>
        <div style="font-size:13px;color:var(--text2)">Review and approve pending registration requests.</div>
      </div>

      <div class="card">
        <div class="card-header">
          <h3>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--blue-light)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 2l-4 4m0 0l-4-4m4 4V14"/></svg>
            Pending Registrations
          </h3>
          <span class="chip chip-late" id="pendingChip">5 pending</span>
        </div>
        <div class="card-body" style="display:block;padding:16px">
          <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px;align-items:center">
            <button class="btn btn-xs btn-ghost" id="rbAll"  onclick="filterReg('all')"     style="background:var(--accent);color:#fff;border-color:var(--accent)">All</button>
            <button class="btn btn-xs btn-ghost" id="rbStu"  onclick="filterReg('student')">Students</button>
            <button class="btn btn-xs btn-ghost" id="rbTea"  onclick="filterReg('teacher')">Teachers</button>
            <button class="btn btn-xs btn-success" style="margin-left:auto" onclick="bulkApprove()">✓ Approve All</button>
            <button class="btn btn-xs btn-danger"             onclick="bulkDecline()">✕ Decline All</button>
          </div>
          <div id="regList"></div>
        </div>
      </div>
    </div><!-- /registrations -->


    <!-- ═══════ ATTENDANCE LOGS ═══════ -->
    <div class="view" id="view-logs">
      <div style="margin-bottom:20px">
        <div style="font-size:22px;font-weight:800;color:var(--text);letter-spacing:-.4px;margin-bottom:3px">Attendance Logs</div>
        <div style="font-size:13px;color:var(--text2)">Filter, review, and export attendance records.</div>
      </div>

      <!-- Mini stats -->
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:16px">
        <div class="metric-card" style="min-height:auto;padding:16px">
          <div class="metric-label">Present</div>
          <div class="metric-value" style="color:var(--green)">4</div>
        </div>
        <div class="metric-card" style="min-height:auto;padding:16px">
          <div class="metric-label">Absent</div>
          <div class="metric-value" style="color:var(--red)">1</div>
        </div>
        <div class="metric-card" style="min-height:auto;padding:16px">
          <div class="metric-label">Late</div>
          <div class="metric-value" style="color:var(--amber)">1</div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h3>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--blue-light)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="12" y2="16"/></svg>
            Records
          </h3>
          <div style="display:flex;gap:8px">
            <button class="btn btn-xs btn-primary" onclick="exportLogs()">↓ Export CSV</button>
            <button class="btn btn-xs btn-danger"  onclick="clearLogs()">Clear All</button>
          </div>
        </div>
        <div class="card-body" style="display:block;padding:16px">
          <!-- Filters -->
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr auto;gap:10px;align-items:end;margin-bottom:14px">
            <div>
              <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text3);margin-bottom:6px">Student</div>
              <div class="search-bar">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input id="fStudent" placeholder="Name…">
              </div>
            </div>
            <div>
              <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text3);margin-bottom:6px">Subject</div>
              <select class="form-select" id="fSubject">
                <option value="">All Subjects</option>
                <option>Python Programming</option>
                <option>Java Programming</option>
                <option>C++ Programming</option>
                <option>JavaScript</option>
                <option>PHP Programming</option>
              </select>
            </div>
            <div>
              <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text3);margin-bottom:6px">Status</div>
              <select class="form-select" id="fStatus">
                <option value="">All Statuses</option>
                <option>Present</option>
                <option>Absent</option>
                <option>Late</option>
              </select>
            </div>
            <div>
              <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text3);margin-bottom:6px">&nbsp;</div>
              <button class="btn btn-primary" style="width:100%" onclick="applyLogFilter()">Filter</button>
            </div>
          </div>
          <div id="filterMsg" style="font-size:12px;color:var(--text3);margin-bottom:6px"></div>
        </div>
        <div style="overflow-x:auto">
          <table class="table" id="logsTable">
            <thead>
              <tr>
                <th>Date</th><th>Student</th><th>Time</th><th>Subject</th><th>Period</th><th>Status</th>
              </tr>
            </thead>
            <tbody id="logsTbody"></tbody>
          </table>
        </div>
      </div>
    </div><!-- /logs -->

  </div><!-- /content -->
</div><!-- /main -->


<!-- ═══════════════════════════════════════════
     MODALS
═══════════════════════════════════════════ -->

<!-- User Profile Modal -->
<div class="modal-overlay" id="profileModal">
  <div class="modal-card" style="max-width:380px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px">
      <h3 id="profileTitle" style="font-size:15px;font-weight:800;color:var(--text)">User Profile</h3>
      <button class="modal-close" onclick="closeModal('profileModal')">&times;</button>
    </div>
    <div id="profileAvatar" style="display:flex;align-items:center;gap:12px;margin-bottom:18px;padding-bottom:16px;border-bottom:1px solid var(--border)"></div>
    <div id="profileBody"></div>
    <button class="btn btn-ghost" style="width:100%;margin-top:16px;justify-content:center" onclick="closeModal('profileModal')">Close</button>
  </div>
</div>

<!-- Add User Modal -->
<div class="modal-overlay" id="addModal">
  <div class="modal-card">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px">
      <h3 style="font-size:15px;font-weight:800;color:var(--text)">Add New User</h3>
      <button class="modal-close" onclick="closeModal('addModal')">&times;</button>
    </div>

    <div style="margin-bottom:12px">
      <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text3);margin-bottom:6px">Role</div>
      <select class="form-select" id="newRole" onchange="onRoleChange()">
        <option value="student">Student</option>
        <option value="teacher">Teacher</option>
      </select>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px">
      <div>
        <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text3);margin-bottom:6px">Full Name</div>
        <input class="form-input" id="newName" placeholder="e.g. Juan Dela Cruz">
      </div>
      <div>
        <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text3);margin-bottom:6px" id="newIdLabel">Student ID</div>
        <input class="form-input" id="newId" placeholder="e.g. 2024-12345">
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px">
      <div>
        <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text3);margin-bottom:6px">Email</div>
        <input class="form-input" id="newEmail" type="email" placeholder="user@school.edu">
      </div>
      <div>
        <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text3);margin-bottom:6px" id="newCourseLabel">Course</div>
        <input class="form-input" id="newCourse" placeholder="e.g. BSCS">
      </div>
    </div>

    <div id="studentOnlyFields" style="margin-bottom:12px">
      <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text3);margin-bottom:6px">Section</div>
      <select class="form-select" id="newSection">
        <option>Section A</option><option>Section B</option><option>Section C</option>
      </select>
    </div>

    <div id="teacherOnlyFields" style="display:none;margin-bottom:12px">
      <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text3);margin-bottom:6px">Faculty / Office</div>
      <input class="form-input" id="newOffice" placeholder="e.g. CS Faculty">
    </div>

    <div style="display:flex;gap:10px;margin-top:6px">
      <button class="btn btn-primary" style="flex:1;justify-content:center" onclick="submitUser()">Create User</button>
      <button class="btn btn-ghost" onclick="closeModal('addModal')">Cancel</button>
    </div>
  </div>
</div>

</div><!-- /#app -->

<script>
  /* ── Mobile menu btn visibility ── */
  function checkMobile() {
    const btn = document.querySelector('.menu-btn');
    if (btn) btn.style.display = window.innerWidth <= 768 ? 'flex' : 'none';
  }
  checkMobile();
  window.addEventListener('resize', checkMobile);

  /* ── Sync dPending2 from dPending ── */
  const _origUpdate = window.updatePendingBadges;
  document.addEventListener('DOMContentLoaded', () => {
    const obs = new MutationObserver(() => {
      const v = document.getElementById('dPending')?.textContent;
      const el2 = document.getElementById('dPending2');
      if (el2 && v) el2.textContent = v;
    });
    const dp = document.getElementById('dPending');
    if (dp) obs.observe(dp, { childList: true, characterData: true, subtree: true });

    /* Sync user counts to dashboard cards */
    const syncCount = (srcId, dstId) => {
      const src = document.getElementById(srcId);
      const dst = document.getElementById(dstId);
      if (!src || !dst) return;
      new MutationObserver(() => { dst.textContent = src.textContent; })
        .observe(src, { childList: true, characterData: true, subtree: true });
    };
    syncCount('uStudents', 'uStudents2');
    syncCount('uStudents', 'mStudents');
    syncCount('uTeachers', 'uTeachers2');
    syncCount('uTeachers', 'mTeachers');
  });
</script>

<script src="/static/admin.js"></script>
</body>
</html>
