<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - AttendTrack</title>
    <link rel="stylesheet" href="/static/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <div class="bg-particles">
        <span></span><span></span><span></span><span></span><span></span><span></span>
    </div>

    <div class="bg-deco"></div>

    <div class="calendar-strip" aria-hidden="true">
        <div class="cal-day marked">MON</div>
        <div class="cal-day marked">TUE</div>
        <div class="cal-day">WED</div>
        <div class="cal-day marked">THU</div>
        <div class="cal-day marked">FRI</div>
        <div class="cal-day">SAT</div>
        <div class="cal-day">SUN</div>
    </div>

    <div class="container">
        <div class="logo-wrap">
            <a href="#" class="logo-icon" aria-label="AttendTrack Home">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M9 12L11 14L15 10M21.0001 12C21.0001 16.9706 16.9707 21 12.0001 21C7.02953 21 3.00009 16.9706 3.00009 12C3.00009 7.02944 7.02953 3 12.0001 3C16.9707 3 21.0001 7.02944 21.0001 12Z" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </a>
        </div>

        <h1>Welcome Back</h1>
        <p class="subtitle">Sign in to your AttendTrack account.</p>

        <% if (locals.error) { %>
            <div class="error-message">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <span><%= locals.error %></span>
            </div>
        <% } %>

        <form action="/login" method="POST" class="info-box">
            <div class="field-group">
                <label for="email">Email Address</label>
                <div class="input-wrap">
                    <span class="input-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    </span>
                    <input type="email" id="email" name="email" placeholder="you@example.com" value="<%= locals.email || '' %>" required>
                </div>
            </div>

            <div class="field-group">
                <label for="password">Password</label>
                <div class="input-wrap">
                    <span class="input-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    </span>
                    <input type="password" id="password" name="password" placeholder="••••••••" required>
                    <button type="button" class="toggle-pw" data-target="password" aria-label="Toggle password visibility">
                        <svg class="eye-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    </button>
                </div>
            </div>

            <button type="submit" class="btn-login" style="margin-top: 18px;">
                <span>Sign In</span>
                <span class="btn-arrow">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
            </button>
        </form>

        <div class="register">
            <p>Don't have an account? <a href="#" id="openRoleModal">Sign up</a></p>
        </div>
    </div>

    <!-- Role Selection Modal -->
    <div id="roleModal" style="display:none; position:fixed; inset:0; background:rgba(11,18,32,.85); backdrop-filter:blur(6px); z-index:10000; align-items:center; justify-content:center;">
        <div style="background:var(--dark-800, #111d30); border:1px solid rgba(79,172,254,.18); padding:36px 32px; border-radius:16px; text-align:center; max-width:340px; width:90%; box-shadow:0 24px 60px rgba(0,0,0,.4); animation:popIn .3s cubic-bezier(.22,1,.36,1) both; position:relative;">
            <button type="button" id="closeRoleModal" style="position:absolute; top:16px; right:16px; background:none; border:none; color:#5a7a9a; cursor:pointer; font-size:24px; line-height:1; padding:4px;">&times;</button>
            <h3 style="color:#e8f2ff; font-size:20px; font-weight:800; margin:0 0 8px;">Join AttendTrack</h3>
            <p style="color:#5a7a9a; font-size:13.5px; margin:0 0 24px;">How would you like to register?</p>
            
            <div style="display:flex; flex-direction:column; gap:14px;">
                <a href="/register?type=student" style="display:flex; align-items:center; gap:12px; padding:16px; background:rgba(11,18,32,.6); border:1.5px solid rgba(79,172,254,.2); border-radius:12px; text-decoration:none; transition:all 0.2s;" onmouseover="this.style.borderColor='#4facfe'; this.style.background='rgba(79,172,254,.08)'" onmouseout="this.style.borderColor='rgba(79,172,254,.2)'; this.style.background='rgba(11,18,32,.6)'">
                    <div style="width:40px; height:40px; border-radius:10px; background:rgba(79,172,254,.15); display:flex; align-items:center; justify-content:center; color:#4facfe;">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    </div>
                    <div style="text-align:left;">
                        <div style="font-weight:700; font-size:15px; color:#fff;">I am a Student</div>
                        <div style="font-size:11px; color:#5a7a9a; margin-top:2px;">Enroll in classes & track attendance</div>
                    </div>
                </a>
                
                <a href="/register?type=teacher" style="display:flex; align-items:center; gap:12px; padding:16px; background:rgba(11,18,32,.6); border:1.5px solid rgba(16,185,129,.2); border-radius:12px; text-decoration:none; transition:all 0.2s;" onmouseover="this.style.borderColor='#10b981'; this.style.background='rgba(16,185,129,.08)'" onmouseout="this.style.borderColor='rgba(16,185,129,.2)'; this.style.background='rgba(11,18,32,.6)'">
                    <div style="width:40px; height:40px; border-radius:10px; background:rgba(16,185,129,.15); display:flex; align-items:center; justify-content:center; color:#10b981;">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </div>
                    <div style="text-align:left;">
                        <div style="font-weight:700; font-size:15px; color:#fff;">I am a Teacher</div>
                        <div style="font-size:11px; color:#5a7a9a; margin-top:2px;">Create classes & manage students</div>
                    </div>
                </a>
            </div>
        </div>
    </div>

    <script>
        document.querySelectorAll('.input-wrap input').forEach(input => {
            const fieldGroup = input.closest('.field-group');
            if (fieldGroup) {
                input.addEventListener('focus', () => fieldGroup.classList.add('focused'));
                input.addEventListener('blur',  () => fieldGroup.classList.remove('focused'));
            }
        });

        const eyeOpen  = `<svg class="eye-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`;
        const eyeClosed = `<svg class="eye-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.94 10.94 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>`;

        document.querySelectorAll('.toggle-pw').forEach(btn => {
            btn.onclick = function () {
                const input = document.getElementById(btn.dataset.target);
                if (!input) return;
                const isPassword = input.type === 'password';
                input.type = isPassword ? 'text' : 'password';
                btn.innerHTML = isPassword ? eyeClosed : eyeOpen;
            };
        });

        // Role Modal Logic
        const roleModal = document.getElementById('roleModal');
        document.getElementById('openRoleModal').addEventListener('click', (e) => {
            e.preventDefault();
            roleModal.style.display = 'flex';
        });
        document.getElementById('closeRoleModal').addEventListener('click', () => {
            roleModal.style.display = 'none';
        });
        roleModal.addEventListener('click', (e) => {
            if (e.target === roleModal) roleModal.style.display = 'none';
        });
    </script>
</body>
</html>