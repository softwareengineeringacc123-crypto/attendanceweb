<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teacher Dashboard | Attendance</title>
    <link rel="stylesheet" href="/static/dashboardstyle.css">
    <style>
        /* ── Sidebar class tree ── */
        .sb-classes { display:flex; flex-direction:column; gap:1px; }

        .sb-class-toggle {
            width:100%; display:flex; align-items:center; gap:8px;
            padding:9px 10px 9px 12px;
            background:rgba(35, 120, 248, 0.841); border:none; text-align:left;
            color:rgba(255,255,255,0.5); font-size:13px; font-weight:500;
            cursor:pointer; border-radius:8px;
            transition:background .15s, color .15s;
            min-width:0;
        }
        .sb-class-toggle:hover { background:rgba(35, 120, 248, 0.841); color:rgba(255,255,255,0.85); }
        .sb-class-toggle.open  { background:rgba(35, 120, 248, 0.841); color:#fff; }

        .sb-class-icon { width:15px; height:15px; flex-shrink:0; color:rgba(99,153,255,0.8); }
        .sb-class-name { flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }

        .sb-chevron {
            width:13px; height:13px; flex-shrink:0; opacity:.4;
            transition:transform .2s ease;
        }
        .sb-class-toggle.open .sb-chevron { transform:rotate(90deg); opacity:.8; }

        .sb-class-children {
            display:none; flex-direction:column; gap:1px;
            padding:4px 0 6px 12px;
        }
        .sb-class-children.open { display:flex; }

        .sb-subject-row {
            display:flex; align-items:center; gap:7px;
            padding:8px 10px; border-radius:8px;
            background:rgba(255,255,255,0.02);
            border:1px solid rgba(255,255,255,0.04);
            margin-bottom:4px;
            transition:all .15s ease;
        }

        /* clickable subject (button variant) */
        .sb-subject-clickable {
            width:100%; border:none; text-align:left; cursor:pointer;
        }
        .sb-subject-clickable:hover {
            background:rgba(255,255,255,0.06);
            border-color:rgba(255,255,255,0.1);
            transform:translateX(2px);
        }

        .sb-subject-name  { flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
        .sb-subject-time  { font-size:10px; opacity:.45; white-space:nowrap; font-family:var(--mono,monospace); }

        /* actions row — add subject + passcode */
        .sb-actions-row {
            display:flex; gap:4px; margin-top:4px; padding-right:4px;
        }

        .sb-add-btn {
            flex:1; display:flex; align-items:center; justify-content:center; gap:5px;
            padding:5px 8px; border-radius:6px;
            background:none; border:1px solid rgba(99,153,255,0.2); text-align:center;
            font-size:11px; font-weight:600; color:rgba(99,153,255,0.7);
            cursor:pointer; transition:background .15s, color .15s, border-color .15s;
        }
        .sb-add-btn:hover {
            background:rgba(99,153,255,0.12); color:rgba(99,153,255,1);
            border-color:rgba(99,153,255,0.4);
        }
        .sb-add-btn svg { width:10px; height:10px; flex-shrink:0; }

        .sb-pass-btn {
            flex:1; display:flex; align-items:center; justify-content:center; gap:5px;
            padding:5px 8px; border-radius:6px;
            background:none; border:1px solid rgba(250,180,60,0.2); text-align:center;
            font-size:11px; font-weight:600; color:rgba(250,180,60,0.7);
            cursor:pointer; transition:background .15s, color .15s, border-color .15s;
        }
        .sb-pass-btn:hover {
            background:rgba(250,180,60,0.1); color:rgba(250,180,60,1);
            border-color:rgba(250,180,60,0.4);
        }
        .sb-pass-btn svg { width:10px; height:10px; flex-shrink:0; }

        /* new class button */
        .sb-new-class-btn {
            display:flex; align-items:center; gap:9px;
            width:100%; padding:9px 12px;
            background:none; border:none; border-radius:8px; text-align:left;
            color:rgba(255,255,255,0.45); font-size:13px; font-weight:500;
            cursor:pointer; transition:background .15s, color .15s; margin-top:2px;
        }
        .sb-new-class-btn:hover { background:rgba(255,255,255,0.06); color:rgba(255,255,255,0.85); }
        .sb-new-class-btn svg   { width:15px; height:15px; flex-shrink:0; }

        .sb-divider { height:1px; background:rgba(255,255,255,0.06); margin:5px 0; }
        .sb-empty   { padding:6px 12px; font-size:12px; color:rgba(255,255,255,0.25); font-style:italic; }

        /* ── Custom Time Picker ── */
        .time-box {
            width: 50px; padding: 8px 4px; border: 1.5px solid var(--border2, rgba(15,23,42,.12)); 
            border-radius: 6px; text-align: center; outline: none; transition: all 0.2s; 
            font-family: var(--mono, monospace); font-size: 14px;
        }
        .time-box:focus { border-color: var(--accent, #1E40AF); box-shadow: 0 0 0 3px rgba(30,64,175,0.1); }
        .time-select {
            padding: 8px 4px; border: 1.5px solid var(--border2, rgba(15,23,42,.12)); 
            border-radius: 6px; outline: none; cursor: pointer; transition: all 0.2s; 
            font-weight: 600; color: var(--ink2, #1e293b); font-size: 13px;
        }
        .time-select:focus { border-color: var(--accent, #1E40AF); box-shadow: 0 0 0 3px rgba(30,64,175,0.1); }
        /* ══════════════════════════════════
   RESPONSIVE / MOBILE STYLES
══════════════════════════════════ */

/* Hamburger button — visible on mobile */
.hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 4px;
    border: none;
    background: none;
}
.hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ink2, #1e293b);
    border-radius: 99px;
    transition: all .25s;
}

/* Sidebar overlay for mobile */
.sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.5);
    z-index: 199;
    backdrop-filter: blur(2px);
}
.sidebar-overlay.active { display: block; }

@media (max-width: 768px) {
    /* Show hamburger */
    .hamburger { display: flex; }

    /* Sidebar slides in from the left */
    .sidebar {
        position: fixed;
        top: 0;
        left: 0;
        height: 100%;
        z-index: 200;
        transform: translateX(-100%);
        transition: transform .28s cubic-bezier(.4,0,.2,1);
        width: 280px !important;
        box-shadow: 4px 0 24px rgba(0,0,0,.25);
    }
    .sidebar.open { transform: translateX(0); }

    /* Main takes full width */
    .app { flex-direction: column; }
    .main { width: 100% !important; margin-left: 0 !important; }

    /* Header adjustments */
    header {
        padding: 0 14px !important;
        height: 56px !important;
    }
    .header-left { gap: 10px; }
    .page-title { font-size: 15px !important; }
    .page-sub { display: none; }
    .time-pill { display: none; }

    /* Content padding */
    .content { padding: 14px !important; }
    .page-header { margin-bottom: 14px !important; }
    .page-header h2 { font-size: 20px !important; }

    /* Dashboard grid — single column */
    .dash-grid {
        grid-template-columns: 1fr !important;
        gap: 12px !important;
        
    }

    /* Attendance panel topbar — stack on mobile */
    .att-topbar {
        height: auto !important;
        flex-wrap: wrap;
        padding: 10px 14px !important;
        gap: 8px !important;
    }
    .att-topbar > div:last-child {
        width: 100%;
        overflow-x: auto;
        padding-bottom: 2px;
    }
    #attSearchInput { width: 100% !important; }

    /* Stats row — 2 cols on mobile */
    #attendanceStatsRow {
        grid-template-columns: 1fr 1fr !important;
        padding: 10px 14px 0 !important;
    }

    /* Table scroll hint */
    .att-table-wrap { -webkit-overflow-scrolling: touch; }

    /* Modals full-width */
    .modal-backdrop > .card,
    .modal-backdrop > div {
        max-width: 100% !important;
        margin: 0 8px !important;
        padding: 20px !important;
    }

    /* Session subject modal */
    #subjectSessionModal > div {
        max-width: 100% !important;
        padding: 20px !important;
    }

    /* Schedule panel */
    #teacherSchedulePanel .sched-outer {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    /* Settings grid — single column */
    .settings-grid {
        grid-template-columns: 1fr !important;
    }

    /* Import modal */
    .imp-panel {
        max-width: 100% !important;
        border-radius: 12px !important;
        max-height: 95vh !important;
    }
}

@media (max-width: 480px) {
    /* Topbar action buttons — icon-only on very small screens */
    .att-action-btn span,
    #attImportBtn span,
    #attExportBtn span { display: none; }

    .page-header h2 { font-size: 17px !important; }

    #attendanceStatsRow {
        grid-template-columns: 1fr 1fr !important;
        gap: 8px !important;
    }

    .att-stat-value { font-size: 20px !important; }

    /* Class items in dashboard */
    .class-item { padding: 8px !important; }
}
    </style>
</head>
<body>
    <div class="app">

    <!-- Mobile sidebar overlay -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <!-- SIDEBAR -->
        <aside class="sidebar" id="mainSidebar">
            <div class="sidebar-top">
                <div class="brand">
                    <div class="brand-mark">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 11l3 3L22 4"/>
                            <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
                        </svg>
                    </div>
                    <div>
                        <div class="brand-name">AttendTrack</div>
                        <div class="brand-sub">Teacher Portal</div>
                    </div>
                </div>
                <div class="student-card">
                    <div class="student-avatar"><%= (sessionUser.name || 'T')[0].toUpperCase() %></div>
                    <div class="student-name"><%= sessionUser.name || 'Teacher' %></div>
                    <div class="student-meta"><%= sessionUser.email %></div>
                    <div class="student-id">Role: <%= sessionUser.role %></div>
                </div>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-section-label">Main</div>
                <a class="nav-item active" href="#dashboard" onclick="showDashboardView(); return false;">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="7" rx="1"/>
                        <rect x="14" y="3" width="7" height="7" rx="1"/>
                        <rect x="14" y="14" width="7" height="7" rx="1"/>
                        <rect x="3" y="14" width="7" height="7" rx="1"/>
                    </svg>
                    Dashboard
                    <span class="nav-active-dot"></span>
                </a>

                <div class="nav-section-label" style="margin-top:8px">Classes</div>

                <!-- Populated by renderSidebarClasses() after loadClasses() -->
                <div class="sb-classes" id="sidebarClassList">
                    <div class="sb-empty">Loading…</div>
                </div>

                <div class="sb-divider"></div>

                <button class="sb-new-class-btn" onclick="openClassModal()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 5v14M5 12h14"/>
                    </svg>
                    New Class
                </button>

<a class="nav-item" id="scheduleNavBtn" href="#schedule" onclick="showScheduleView(); return false;">
    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
        <line x1="16" y1="2" x2="16" y2="6"/>
        <line x1="8" y1="2" x2="8" y2="6"/>
        <line x1="3" y1="10" x2="21" y2="10"/>
    </svg>
    Schedule
</a>
                <div class="nav-section-label" style="margin-top:8px">Account</div>
<a class="nav-item" id="settingsNavBtn" href="#settings" onclick="showSettingsView(); return false;">
    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3"/>
        <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>
    </svg>
    Settings
</a>
            </nav>
        </aside>

        <div class="main">
            <!-- HEADER -->
            <header>
              <div class="header-left">
                <div class="hamburger" id="hamburger"><span></span><span></span><span></span></div>
                <div>
                  <div class="page-title" id="pageTitle">Dashboard</div>
                  <div class="page-sub" id="pageSub">Welcome back, <%= sessionUser.name || 'Teacher' %></div>
                </div>
              </div>
              <div class="header-right">
                <div class="time-pill"><div class="time-dot"></div><span id="liveTime">—</span></div>
                <div style="position:relative">
                  <div class="hdr-btn" id="notifBtn" title="Notifications">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                        <path d="M13.73 21a2 2 0 01-3.46 0"/>
                    </svg>
                    <div class="notif-dot"></div>
                  </div>
                  <div id="notifDropdown" class="card shadow-lg"
                       style="display:none;position:absolute;top:45px;right:0;width:320px;z-index:1000;">
                    <div class="card-header">
                      <h3>Notifications</h3>
                      <span style="font-size:11px;color:var(--accent);font-weight:600;cursor:pointer">Mark all read</span>
                    </div>
                    <div class="card-body" style="max-height:380px;overflow-y:auto;padding:12px"></div>
                  </div>
                </div>
                <div style="position:relative">
                  <div class="hdr-btn" id="profileBtn" title="Account">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                  </div>
                  <div id="profileDropdown" class="card shadow-lg"
     style="display:none;position:absolute;top:50px;right:0;width:240px;z-index:1000;
            border-radius:12px;overflow:hidden;box-shadow:0 8px 24px rgba(0,0,0,.12);
            border:1px solid var(--border,rgba(15,23,42,.08))">

  <!-- User info section -->
  <div style="padding:16px;border-bottom:1px solid var(--border,rgba(15,23,42,.08));
              display:flex;align-items:center;gap:10px">
    <div style="width:38px;height:38px;border-radius:10px;flex-shrink:0;
                background:linear-gradient(135deg,#1E40AF,#6B8AFF);
                display:grid;place-items:center;font-size:15px;font-weight:700;color:#fff">
      <%= (sessionUser.name || 'T')[0].toUpperCase() %>
    </div>
    <div style="overflow:hidden;min-width:0">
      <div style="font-size:13px;font-weight:700;color:var(--ink2,#1e293b);
                  white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
        <%= sessionUser.name || 'Teacher' %>
      </div>
      <div style="font-size:11px;color:var(--ink5,#64748b);
                  white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
        <%= sessionUser.email %>
      </div>
      <div style="margin-top:3px;display:inline-flex;align-items:center;gap:4px;
                  padding:2px 7px;border-radius:999px;background:#eff6ff;
                  font-size:10px;font-weight:700;color:#1E40AF;text-transform:capitalize">
        <span style="width:5px;height:5px;border-radius:50%;background:#1E40AF"></span>
        <%= sessionUser.role %>
      </div>
    </div>
  </div>

  <!-- Actions -->
  <div style="padding:8px">
    <button id="logoutBtn"
      style="width:100%;display:flex;align-items:center;gap:9px;padding:9px 12px;
             border-radius:8px;border:none;background:none;cursor:pointer;
             font-size:13px;font-weight:600;color:#ef4444;text-align:left;
             transition:background .15s"
      onmouseover="this.style.background='#fef2f2'"
      onmouseout="this.style.background='none'">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
        <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
      Logout
    </button>
  </div>
</div>
                </div>
              </div>
            </header>

            <!-- CONTENT -->
            <div class="content">
                <div class="page-header animate-in">
                    <h2 id="dashGreeting">Good morning 👋</h2>
                    <p>Manage your classes and attendance</p>
                </div>

                <div class="dash-grid">
                    <div id="pendingEnrollmentsAnchor"></div>
                    <!-- CLASSES TODAY -->
                    <div class="card scale-in" style="margin-bottom: 20px;">
                        <div class="card-header">
                            <h3>Classes Today</h3>
                        </div>
                        <div class="card-body" style="padding:0">
                            <div id="todayClassList">
                                <div style="padding:24px 18px;text-align:center;color:var(--ink4);font-size:13px">Loading today's classes...</div>
                            </div>
                        </div>
                    </div>

                    <div class="card scale-in">
                        <div class="card-header">
                            <h3>My Classes</h3>
                            <button class="btn btn-primary" onclick="openClassModal()">+ New Class</button>
                        </div>
                        <div class="card-body">
                            <div id="classList" class="class-list">
                                <div class="class-item" style="cursor:default">No classes yet. Create one to begin.</div>
                            </div>
                        </div>
                    </div>

                    <div class="card scale-in">
                        <div class="card-header"><h3>Recent Sessions</h3></div>
                        <div class="card-body" style="max-height:400px;overflow-y:auto">
                            <div id="sessionsContainer">
                                <div style="padding:14px;text-align:center;color:var(--ink4)">
                                    No attendance sessions yet.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SCHEDULE VIEW -->
<div id="teacherSchedulePanel" style="display:none">
    <div class="page-header animate-in">
        <h2>Weekly Schedule</h2>
        <p>All your subjects across all classes</p>
    </div>
    <div class="card animate-in" style="margin-bottom:14px">
        <div id="teacherSchedGrid"></div>
    </div>
    <div class="card animate-in">
        <div class="card-header"><h3>Subject Details</h3></div>
        <div style="overflow-x:auto">
            <table class="schedule-table">
                <thead>
                    <tr>
                        <th>Class</th>
                        <th>Subject</th>
                        <th>Days</th>
                        <th>Time</th>
                        <th>Room</th>
                    </tr>
                </thead>
                <tbody id="teacherSchedSubjectBody"></tbody>
            </table>
        </div>
    </div>
</div>

<!-- ══════════ SETTINGS VIEW ══════════ -->
<div id="teacherSettingsPanel" class="view" style="display:none;">
  <div class="page-header">
    <h2 id="pageTitle">Settings</h2>
    <p id="pageSub">Profile & Preferences</p>
  </div>
  
  <div class="settings-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; align-items: start;">

    <!-- Profile Card -->
    <div class="card">
      <div class="card-header" style="padding: 16px 18px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
        <h3 style="font-size: 14px; font-weight: 700; color: var(--ink2); margin: 0;">Profile Information</h3>
        <button class="btn btn-ghost" id="editTeacherProfileBtn" onclick="toggleTeacherProfileEdit()" style="font-size:11.5px;padding:5px 12px;height:auto">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          Edit Profile
        </button>
      </div>
      <div class="card-body" style="padding: 18px;">
        
        <!-- Avatar Upload Section -->
        <div style="display:flex; align-items:center; gap:20px; margin-bottom:24px;">
          <div style="position:relative; width:80px; height:80px; border-radius:14px; overflow:hidden; border:2px solid var(--border2); background:linear-gradient(135deg,var(--accent),#6B8AFF); display:grid; place-items:center;">
            <img id="teacherAvatarImg" src="" style="display:none; width:100%; height:100%; object-fit:cover; position:absolute; inset:0; z-index:2;">
            <div id="teacherAvatarInitials" style="font-size:28px; font-weight:800; color:white; z-index:1;">T</div>
          </div>
          <div id="avatarUploadBtnWrapper" style="display:none;">
            <input type="file" id="avatarUpload" accept="image/*" style="display:none" onchange="handleAvatarUpload(event)">
            <button type="button" class="btn btn-ghost" onclick="document.getElementById('avatarUpload').click()" style="font-size:13px; font-weight:600; padding: 8px 16px; border-radius: 8px; cursor: pointer;">
              Upload Photo
            </button>
            <div style="font-size:11px; color:var(--ink5); margin-top:6px;">JPG, GIF or PNG. Max size of 2MB.</div>
          </div>
        </div>

        <!-- Form Fields -->
        <div class="form-group" style="margin-bottom:16px;">
          <label style="display:block; font-size:12px; font-weight:600; color:var(--ink4); margin-bottom:6px;">Full Name</label>
          <input id="settingsName" type="text" readonly style="width:100%; padding:10px 12px; border:1.5px solid var(--border2); border-radius:8px; font-size:14px; outline:none; box-sizing:border-box; background:var(--surface2, #f8fafc); cursor:not-allowed;">
        </div>
        <div class="form-group" style="margin-bottom:16px;">
          <label style="display:block; font-size:12px; font-weight:600; color:var(--ink4); margin-bottom:6px;">Department / Faculty</label>
          <input id="settingsDept" type="text" readonly style="width:100%; padding:10px 12px; border:1.5px solid var(--border2); border-radius:8px; font-size:14px; outline:none; box-sizing:border-box; background:var(--surface2, #f8fafc); cursor:not-allowed;" placeholder="e.g. IT Department">
        </div>
        <div class="form-group" style="margin-bottom:24px;">
          <label style="display:block; font-size:12px; font-weight:600; color:var(--ink4); margin-bottom:6px;">Email Address</label>
          <input id="settingsEmail" type="text" readonly style="width:100%; padding:10px 12px; border:1.5px solid var(--border2); border-radius:8px; font-size:14px; outline:none; box-sizing:border-box; background:var(--surface2, #f8fafc); color:var(--ink5); cursor:not-allowed;">
        </div>
        <button id="saveProfileBtn" onclick="saveTeacherProfile()" style="display:none; width:100%; padding:12px; border-radius:8px; border:none; background:var(--accent, #1E40AF); color:white; font-size:14px; font-weight:600; cursor:pointer; transition: background 0.2s;" onmouseover="this.style.background='#1e3a8a'" onmouseout="this.style.background='var(--accent)'">
          Save Profile Changes
        </button>
      </div>
    </div>

    <!-- Password & Security Card -->
    <div class="card">
      <div class="card-header" style="padding: 16px 18px; border-bottom: 1px solid var(--border);">
        <h3 style="font-size: 14px; font-weight: 700; color: var(--ink2); margin: 0;">Password & Security</h3>
      </div>
      <div class="card-body" style="padding: 18px;">
        <div style="margin-bottom:16px;"><label style="display:block; font-size:12px; font-weight:600; color:var(--ink4); margin-bottom:6px;">Current Password</label><input type="password" style="width:100%; padding:10px 12px; border:1.5px solid var(--border2); border-radius:8px; font-size:14px; outline:none; box-sizing:border-box;" placeholder="Enter current password"></div>
        <div style="margin-bottom:16px;"><label style="display:block; font-size:12px; font-weight:600; color:var(--ink4); margin-bottom:6px;">New Password</label><input type="password" style="width:100%; padding:10px 12px; border:1.5px solid var(--border2); border-radius:8px; font-size:14px; outline:none; box-sizing:border-box;" placeholder="Create a strong password"></div>
        <div style="margin-bottom:24px;"><label style="display:block; font-size:12px; font-weight:600; color:var(--ink4); margin-bottom:6px;">Confirm New Password</label><input type="password" style="width:100%; padding:10px 12px; border:1.5px solid var(--border2); border-radius:8px; font-size:14px; outline:none; box-sizing:border-box;" placeholder="Re-enter new password"></div>
        <button style="width:100%; padding:12px; border-radius:8px; border:1.5px solid var(--border2); background:transparent; color:var(--ink2); font-size:14px; font-weight:600; cursor:pointer; transition: background 0.2s;" onmouseover="this.style.background='var(--surface2, #f8fafc)'" onmouseout="this.style.background='transparent'">Update Password</button>
      </div>
    </div>
  </div>
</div>

            </div>
        </div>
    </div>

    <!-- ── Class Modal ── -->
    <div class="modal-backdrop" id="classModal"
         style="display:none;position:fixed;inset:0;background:rgba(37, 96, 235, 0.75);
                backdrop-filter:blur(4px);z-index:1200;align-items:center;
                justify-content:center;padding:20px">
        <div class="card"
             style="max-width:560px;width:100%;padding:28px;position:relative;
                    max-height:calc(100vh - 80px);overflow-y:auto;">
            <button type="button" onclick="hideClassModal()"
                    style="position:absolute;top:18px;right:18px;border:none;background:none;
                           color:var(--ink5);font-size:20px;cursor:pointer">×</button>
            <h3 id="formStepTitle" style="margin-bottom:14px">Create New Class</h3>

            <!-- Step 1 -->
            <div id="step1" class="form-step" style="display:block">
                <div class="form-group" style="margin-bottom:14px">
                    <label>Class Name <span style="color:red">*</span></label>
                    <input type="text" id="classNameInput" placeholder="Example: CS201" />
                </div>
            </div>

            <!-- Step 2 -->
            <div id="step2" class="form-step" style="display:none">
                <div style="margin-bottom:16px;padding-bottom:14px;border-bottom:1px solid var(--ink6)">
                    <div style="font-size:13px;color:var(--ink5);margin-bottom:4px">Class Name:</div>
                    <div id="classNameDisplay" style="font-weight:600;color:var(--ink0)">—</div>
                </div>
                <h4 style="margin-bottom:14px">Add Subjects to Class</h4>
                <div class="form-group" style="margin-bottom:14px">
                    <label>Subject Name <span style="color:red">*</span></label>
                    <input type="text" id="subjectNameInputClass" placeholder="Example: Data Structures" />
                </div>
                <div class="form-row" style="gap:14px;flex-wrap:wrap;margin-bottom:14px">
                    <div class="form-group" style="flex:1;min-width:140px">
                        <label style="display:block;margin-bottom:6px">Start Time <span style="color:red">*</span></label>
                        <input type="hidden" id="subjectStartTimeClass" value="08:00" />
                        <div style="display:flex;align-items:center;gap:6px">
                            <input type="number" id="st_h_c" value="8" class="time-box" onchange="updateTimeStr('subjectStartTimeClass','st_h_c','st_m_c','st_a_c')">
                            <span style="font-weight:bold;color:var(--ink3)">:</span>
                            <input type="number" id="st_m_c" value="00" class="time-box" onchange="updateTimeStr('subjectStartTimeClass','st_h_c','st_m_c','st_a_c')">
                            <select id="st_a_c" class="time-select" onchange="updateTimeStr('subjectStartTimeClass','st_h_c','st_m_c','st_a_c')">
                                <option value="AM" selected>AM</option>
                                <option value="PM">PM</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group" style="flex:1;min-width:140px">
                        <label style="display:block;margin-bottom:6px">End Time <span style="color:red">*</span></label>
                        <input type="hidden" id="subjectEndTimeClass" value="09:30" />
                        <div style="display:flex;align-items:center;gap:6px">
                            <input type="number" id="et_h_c" value="9" class="time-box" onchange="updateTimeStr('subjectEndTimeClass','et_h_c','et_m_c','et_a_c')">
                            <span style="font-weight:bold;color:var(--ink3)">:</span>
                            <input type="number" id="et_m_c" value="30" class="time-box" onchange="updateTimeStr('subjectEndTimeClass','et_h_c','et_m_c','et_a_c')">
                            <select id="et_a_c" class="time-select" onchange="updateTimeStr('subjectEndTimeClass','et_h_c','et_m_c','et_a_c')">
                                <option value="AM" selected>AM</option>
                                <option value="PM">PM</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="form-group" style="margin-bottom:14px">
                    <label>Room/Location</label>
                    <input type="text" id="subjectRoomInputClass" placeholder="Example: CL-201" />
                </div>
                <div class="form-group" style="margin-bottom:14px">
                    <label>Class Days <span style="color:red">*</span></label>
                    <div class="days-selection-class"
                         style="display:grid;grid-template-columns:repeat(4,minmax(60px,1fr));
                                gap:8px;margin:10px 0 0">
                        <label style="display:flex;align-items:center;gap:4px;font-size:13px"><input type="checkbox" class="subjectDayCheckbox" value="Mon"> Mon</label>
                        <label style="display:flex;align-items:center;gap:4px;font-size:13px"><input type="checkbox" class="subjectDayCheckbox" value="Tue"> Tue</label>
                        <label style="display:flex;align-items:center;gap:4px;font-size:13px"><input type="checkbox" class="subjectDayCheckbox" value="Wed"> Wed</label>
                        <label style="display:flex;align-items:center;gap:4px;font-size:13px"><input type="checkbox" class="subjectDayCheckbox" value="Thu"> Thu</label>
                        <label style="display:flex;align-items:center;gap:4px;font-size:13px"><input type="checkbox" class="subjectDayCheckbox" value="Fri"> Fri</label>
                        <label style="display:flex;align-items:center;gap:4px;font-size:13px"><input type="checkbox" class="subjectDayCheckbox" value="Sat"> Sat</label>
                        <label style="display:flex;align-items:center;gap:4px;font-size:13px"><input type="checkbox" class="subjectDayCheckbox" value="Sun"> Sun</label>
                    </div>
                </div>
                <div id="subjectsAddedContainer"
                     style="display:none;margin-bottom:16px;padding:12px;background:var(--ink1);
                            border-radius:6px;border-left:3px solid #0EA5E9">
                    <div style="font-size:12px;color:var(--ink5);margin-bottom:8px">Subjects Added:</div>
                    <div id="subjectsAddedList"></div>
                </div>
            </div>

            <div style="display:flex;justify-content:space-between;gap:10px;margin-top:22px">
                <button class="btn btn-ghost" id="prevBtn" type="button"
                        onclick="previousStep()" style="display:none">← Previous</button>
                <div style="flex:1"></div>
                <button class="btn btn-ghost" type="button" onclick="hideClassModal()">Cancel</button>
                <button class="btn btn-primary" id="nextBtn" type="button" onclick="nextStep()">Next →</button>
                <button class="btn btn-primary" id="addSubjectBtn" type="button"
                        onclick="addSubjectToClass()" style="display:none">+ Add Subject</button>
                <button class="btn btn-primary" id="saveBtn" type="button"
                        onclick="submitClassForm()" style="display:none">✓ Save Class</button>
            </div>
        </div>
    </div>

    <!-- ── Subject Modal ── -->
    <div class="modal-backdrop" id="subjectModal"
         style="display:none;position:fixed;inset:0;background:rgba(29, 88, 227, 0.75);
                backdrop-filter:blur(4px);z-index:1200;align-items:center;
                justify-content:center;padding:20px">
        <div class="card" style="max-width:560px;width:100%;padding:28px;position:relative;">
            <button type="button" onclick="hideSubjectModal()"
                    style="position:absolute;top:18px;right:18px;border:none;background:none;
                           color:var(--ink5);font-size:20px;cursor:pointer">×</button>
            <h3 style="margin-bottom:14px">Add Subject to Class</h3>
            <div class="form-group" style="margin-bottom:14px">
                <label>Subject Name <span style="color:red">*</span></label>
                <input type="text" id="subjectNameInput" placeholder="Example: Data Structures" />
            </div>
            <div class="form-row" style="display:flex;gap:14px;flex-wrap:wrap;margin-bottom:14px">
                <div class="form-group" style="flex:1;min-width:140px">
                    <label style="display:block;margin-bottom:6px">Start Time <span style="color:red">*</span></label>
                    <input type="hidden" id="subjectStartTime" value="08:00" />
                    <div style="display:flex;align-items:center;gap:6px">
                        <input type="number" id="st_h_s" value="8" class="time-box" onchange="updateTimeStr('subjectStartTime','st_h_s','st_m_s','st_a_s')">
                        <span style="font-weight:bold;color:var(--ink3)">:</span>
                        <input type="number" id="st_m_s" value="00" class="time-box" onchange="updateTimeStr('subjectStartTime','st_h_s','st_m_s','st_a_s')">
                        <select id="st_a_s" class="time-select" onchange="updateTimeStr('subjectStartTime','st_h_s','st_m_s','st_a_s')">
                            <option value="AM" selected>AM</option>
                            <option value="PM">PM</option>
                        </select>
                    </div>
                </div>
                <div class="form-group" style="flex:1;min-width:140px">
                    <label style="display:block;margin-bottom:6px">End Time <span style="color:red">*</span></label>
                    <input type="hidden" id="subjectEndTime" value="09:30" />
                    <div style="display:flex;align-items:center;gap:6px">
                        <input type="number" id="et_h_s" value="9" class="time-box" onchange="updateTimeStr('subjectEndTime','et_h_s','et_m_s','et_a_s')">
                        <span style="font-weight:bold;color:var(--ink3)">:</span>
                        <input type="number" id="et_m_s" value="30" class="time-box" onchange="updateTimeStr('subjectEndTime','et_h_s','et_m_s','et_a_s')">
                        <select id="et_a_s" class="time-select" onchange="updateTimeStr('subjectEndTime','et_h_s','et_m_s','et_a_s')">
                            <option value="AM" selected>AM</option>
                            <option value="PM">PM</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="form-group" style="margin-bottom:14px">
                <label>Room/Location</label>
                <input type="text" id="subjectRoomInput" placeholder="Example: CL-201" />
            </div>
            <div class="form-group" style="margin-bottom:14px">
                <label>Class Days <span style="color:red">*</span></label>
                <div style="display:grid;grid-template-columns:repeat(4,minmax(60px,1fr));gap:8px;margin:10px 0 0">
                    <label style="display:flex;align-items:center;gap:4px;font-size:13px"><input type="checkbox" class="subjectDayCheckboxModal" value="Mon"> Mon</label>
                    <label style="display:flex;align-items:center;gap:4px;font-size:13px"><input type="checkbox" class="subjectDayCheckboxModal" value="Tue"> Tue</label>
                    <label style="display:flex;align-items:center;gap:4px;font-size:13px"><input type="checkbox" class="subjectDayCheckboxModal" value="Wed"> Wed</label>
                    <label style="display:flex;align-items:center;gap:4px;font-size:13px"><input type="checkbox" class="subjectDayCheckboxModal" value="Thu"> Thu</label>
                    <label style="display:flex;align-items:center;gap:4px;font-size:13px"><input type="checkbox" class="subjectDayCheckboxModal" value="Fri"> Fri</label>
                    <label style="display:flex;align-items:center;gap:4px;font-size:13px"><input type="checkbox" class="subjectDayCheckboxModal" value="Sat"> Sat</label>
                    <label style="display:flex;align-items:center;gap:4px;font-size:13px"><input type="checkbox" class="subjectDayCheckboxModal" value="Sun"> Sun</label>
                </div>
            </div>
            <div style="display:flex;justify-content:flex-end;gap:10px;margin-top:22px">
                <button class="btn btn-ghost" type="button" onclick="hideSubjectModal()">Cancel</button>
                <button class="btn btn-primary" type="button" onclick="submitSubjectForm()">Add Subject</button>
            </div>
        </div>
    </div>

    <!-- ── Passcode Modal ── -->
    <div class="modal-backdrop" id="passcodeModal"
         style="display:none;position:fixed;inset:0;background:rgba(34,212,102,0.2);
                backdrop-filter:blur(4px);z-index:1200;align-items:center;
                justify-content:center;padding:20px">
        <div class="card" style="max-width:420px;width:100%;padding:28px;position:relative;">
            <button type="button" onclick="closePasscodeModal()"
                    style="position:absolute;top:18px;right:18px;border:none;background:none;
                           color:var(--ink5);font-size:20px;cursor:pointer">×</button>
            <h3 style="margin-bottom:8px">Start Attendance Session</h3>
            <p style="color:var(--ink5);font-size:13px;margin-bottom:18px">Enter the passcode for this session or leave blank for no passcode</p>
            
            <div class="form-group" style="margin-bottom:18px">
                <label>Session Passcode <span style="color:#999">(optional)</span></label>
                <input type="text" id="passcodeInput" placeholder="e.g. 1234" style="font-size:16px;letter-spacing:2px;text-align:center;font-weight:600" />
            </div>

            <div style="display:flex;justify-content:flex-end;gap:10px">
                <button class="btn btn-ghost" type="button" onclick="closePasscodeModal()">Cancel</button>
                <button class="btn btn-primary" type="button" onclick="submitPasscodeForm()" style="background:#22d466;border:none">Start Session</button>
            </div>
        </div>
    </div>

    <!-- ── Subject Enrollment Code Modal ── -->
    <div class="modal-backdrop" id="enrollmentModal"
         style="display:none;position:fixed;inset:0;background:rgba(59,130,246,0.15);
                backdrop-filter:blur(4px);z-index:1200;align-items:center;
                justify-content:center;padding:20px">
        <div class="card" style="max-width:500px;width:100%;padding:32px;position:relative;
                    border-left:4px solid #3b82f6">
            <button type="button" onclick="closeEnrollmentModal()"
                    style="position:absolute;top:18px;right:18px;border:none;background:none;
                           color:var(--ink5);font-size:24px;cursor:pointer">×</button>
            
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px">
                <div style="width:44px;height:44px;border-radius:12px;background:#dbeafe;
                           display:grid;place-items:center;flex-shrink:0;font-size:24px">📚</div>
                <div>
                    <h3 id="enrollSubjectName" style="margin:0;font-size:16px;color:var(--ink2)">Subject Name</h3>
                    <div id="enrollClassName" style="font-size:12px;color:var(--ink5);margin-top:2px">Class Name</div>
                </div>
            </div>

            <!-- Subject ID -->
            <div style="margin-bottom:20px;padding:16px;background:#f0f9ff;border-radius:10px;
                       border:1px solid #bfdbfe">
                <div style="font-size:11px;font-weight:600;color:#1e40af;text-transform:uppercase;
                           margin-bottom:8px;letter-spacing:0.5px">Subject ID</div>
                <div style="display:flex;align-items:center;gap:10px">
                    <div id="enrollSubjectId" style="flex:1;font-size:18px;font-weight:700;
                                                     color:#1e40af;font-family:monospace;
                                                     word-break:break-all">—</div>
                    <button id="copySubjectIdBtn" type="button"
                            style="display:flex;align-items:center;justify-content:center;
                                  width:40px;height:40px;border-radius:8px;border:1.5px solid #bfdbfe;
                                  background:#ffffff;cursor:pointer;color:#1e40af;font-size:18px;
                                  transition:all 0.2s;flex-shrink:0"
                            title="Copy subject ID">
                        📋
                    </button>
                </div>
                <div style="font-size:11px;color:#0c4a6e;margin-top:8px">
                    Share this ID with students for class enrollment
                </div>
            </div>

            <!-- Enrollment Code -->
            <div style="margin-bottom:20px;padding:16px;background:#f0fdf4;border-radius:10px;
                       border:1px solid #bbf7d0">
                <div style="font-size:11px;font-weight:600;color:#15803d;text-transform:uppercase;
                           margin-bottom:8px;letter-spacing:0.5px">Enrollment Code</div>
                <div style="display:flex;align-items:center;gap:10px">
                    <div id="enrollmentCode" style="flex:1;font-size:20px;font-weight:700;
                                                   color:#15803d;font-family:monospace;
                                                   letter-spacing:4px;text-align:center">—</div>
                    <button id="copyCodeBtn" type="button"
                            style="display:flex;align-items:center;justify-content:center;
                                  width:40px;height:40px;border-radius:8px;border:1.5px solid #bbf7d0;
                                  background:#ffffff;cursor:pointer;color:#15803d;font-size:18px;
                                  transition:all 0.2s;flex-shrink:0"
                            title="Copy enrollment code">
                        📋
                    </button>
                </div>
                <div style="font-size:11px;color:#166534;margin-top:8px">
                    Students use this code to join the class
                </div>
            </div>

            <!-- Instructions -->
            <div style="background:#fef3c7;border-radius:10px;border:1px solid #fcd34d;
                       padding:14px;margin-bottom:20px">
                <div style="display:flex;gap:10px">
                    <span style="font-size:18px;flex-shrink:0">ℹ️</span>
                    <div>
                        <div style="font-size:12px;font-weight:600;color:#92400e;margin-bottom:4px">
                            How to use:
                        </div>
                        <ul style="margin:0;padding-left:20px;font-size:11px;color:#78350f;line-height:1.6">
                            <li>Share the Subject ID or Enrollment Code with students</li>
                            <li>Students can use either to enroll in this subject</li>
                            <li>Once enrolled, they can mark attendance for this class</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div style="display:flex;justify-content:flex-end;gap:10px">
                <button class="btn btn-secondary" type="button" onclick="closeEnrollmentModal()">Close</button>
                <button class="btn btn-primary" id="shareBtn" type="button"
                        style="display:flex;align-items:center;gap:8px;background:#3b82f6;border:none">
                    <span>🔗</span> Share
                </button>
            </div>
        </div>
    </div>

    <script src="/static/teacherdata.js"></script>
</body>
</html>