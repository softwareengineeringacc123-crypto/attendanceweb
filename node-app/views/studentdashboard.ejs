<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard | Attendance</title>
    <link rel="stylesheet" href="/dashboardstyle.css">
</head>
<body>
    <div class="app">
        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="sidebar-top">
                <div class="brand">
                    <div class="brand-mark">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
                    </div>
                    <div>
                        <div class="brand-name">AttendTrack</div>
                        <div class="brand-sub">Student Portal</div>
                    </div>
                </div>
                <div class="student-card">
                    <div class="student-avatar"><%= (sessionUser.name || 'U')[0].toUpperCase() %></div>
                    <div class="student-name"><%= sessionUser.name || 'Student' %></div>
                    <div class="student-meta"><%= sessionUser.email %></div>
                    <div class="student-id">Role: <%= sessionUser.role %></div>
                </div>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-section-label">Main</div>
                <a class="nav-item active" href="#dashboard">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
                    Dashboard
                    <span class="nav-active-dot"></span>
                </a>
                <div class="nav-section-label" style="margin-top:8px">Account</div>
                <a class="nav-item" href="/logout">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16,17 21,12 16,7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    Logout
                </a>
            </nav>
        </aside>

        <div class="main">
            <!-- HEADER -->
            <header>
                <div class="header-left">
                    <div class="hamburger">
                        <span></span><span></span><span></span>
                    </div>
                    <div>
                        <div class="page-title">Dashboard</div>
                        <div class="page-sub">Welcome back, <%= sessionUser.name || 'Student' %></div>
                    </div>
                </div>
                <div class="header-right">
                    <div class="time-pill">
                        <div class="time-dot"></div>
                        <span id="liveTime">—</span>
                    </div>
                </div>
            </header>

            <!-- CONTENT -->
            <div class="content">
                <div class="page-header animate-in">
                    <h2>Good morning, <%= sessionUser.name || 'Student' %> 👋</h2>
                    <p>Here's your attendance overview</p>
                </div>

                <div class="stats-row">
                    <div class="stat-card animate-in">
                        <div class="stat-top">
                            <div class="stat-icon">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                            </div>
                            <span class="stat-trend">Present</span>
                        </div>
                        <div class="stat-label">Present</div>
                        <div class="stat-value">—</div>
                        <div class="stat-desc">sessions attended</div>
                    </div>
                    <div class="stat-card animate-in">
                        <div class="stat-top">
                            <div class="stat-icon">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
                            </div>
                            <span class="stat-trend">Absent</span>
                        </div>
                        <div class="stat-label">Absent</div>
                        <div class="stat-value">—</div>
                        <div class="stat-desc">sessions missed</div>
                    </div>
                    <div class="stat-card animate-in">
                        <div class="stat-top">
                            <div class="stat-icon">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#F59E0B" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l2 2"/></svg>
                            </div>
                            <span class="stat-trend">Late</span>
                        </div>
                        <div class="stat-label">Late</div>
                        <div class="stat-value">—</div>
                        <div class="stat-desc">late arrivals</div>
                    </div>
                    <div class="stat-card animate-in">
                        <div class="stat-top">
                            <div class="stat-icon">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4361EE" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                            </div>
                            <span class="stat-trend">Rate</span>
                        </div>
                        <div class="stat-label">Attendance Rate</div>
                        <div class="stat-value">—%</div>
                        <div class="stat-desc">overall</div>
                    </div>
                </div>

                <div class="card scale-in">
                    <div class="card-header">
                        <h3>Recent Activity</h3>
                    </div>
                    <div class="card-body">
                        <p>Welcome to your student dashboard. Attendance tracking features will be available here.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/script.js"></script>
